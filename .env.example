# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Pinned model version — do not use "latest" in production
ANTHROPIC_MODEL_ID=claude-3-5-sonnet-20241022

# ── Vercel ────────────────────────────────────────────────────────────────────
VERCEL_BLOB_READ_WRITE_TOKEN=
# Shared secret for the queue webhook (Bearer token). REQUIRED in production —
# the webhook rejects all requests if unset outside development.
VERCEL_QUEUE_TOKEN=
# Optional override for the queue webhook URL. Defaults to
# ${NEXT_PUBLIC_APP_URL}/api/webhooks/queue
VERCEL_QUEUE_URL=
VERCEL_URL=
VERCEL_ENV=development

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# Transaction pooler (used by Prisma Client at runtime)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (used by Prisma Migrate)
DIRECT_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Queue (Future/Fallback: BullMQ + Upstash Redis — not required for MVP) ───
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# REDIS_URL=

# ── Observability ─────────────────────────────────────────────────────────────
AXIOM_API_TOKEN=
AXIOM_DATASET=hvac-visualizer
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# DANGER: "true" bypasses ALL auth (preview/demo only). Never set in production.
PREVIEW_MODE=false
RENDER_MAX_ATTEMPTS=3
RENDER_WORKER_TIMEOUT_MS=55000
SHARE_LINK_TTL_SECONDS=2592000
BLOB_RETENTION_RENDERS_DAYS=365
BLOB_RETENTION_SOURCES_DAYS=90
BLOB_RETENTION_ANALYSIS_DAYS=30

# ── Cron security ─────────────────────────────────────────────────────────────
# Vercel sets this automatically in production; set manually for local cron testing
CRON_SECRET=

# ── fal.ai (AI image generation) ──────────────────────────────────────────────
FAL_KEY=
# "max" = Flux Pro Kontext Max (~$0.055/image); "pro" = cheaper but lower quality
FAL_MODEL_TIER=max
FAL_COST_PER_IMAGE_USD=0.055
RENDER_BUDGET_CAP_USD=0.40

# ── Cost alerting ─────────────────────────────────────────────────────────────
DAILY_COST_ALERT_THRESHOLD_USD=0.35
WEEKLY_COST_REPORT_EMAIL=
