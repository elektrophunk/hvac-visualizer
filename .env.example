# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Pinned model version — do not use "latest" in production
ANTHROPIC_MODEL_ID=claude-3-5-sonnet-20241022

# ── Vercel ────────────────────────────────────────────────────────────────────
VERCEL_BLOB_READ_WRITE_TOKEN=
# Shared secret for the queue webhook (Bearer token). REQUIRED in production —
# the webhook rejects all requests if unset outside development.
VERCEL_QUEUE_TOKEN=
# Optional override for the queue webhook URL. Defaults to
# ${NEXT_PUBLIC_APP_URL}/api/webhooks/queue
VERCEL_QUEUE_URL=
VERCEL_URL=
VERCEL_ENV=development

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# Transaction pooler (used by Prisma Client at runtime)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection (used by Prisma Migrate)
DIRECT_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Upstash Redis (rate limiting; also future BullMQ fallback) ───────────────
# When unset, rate limiting is disabled (local dev only — set in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# REDIS_URL=

# ── Stripe (billing) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Recurring price IDs for the paid plans (Stripe Dashboard → Products)
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_TEAM=

# ── Cloudflare Turnstile (CAPTCHA on signup + free-tier render submit) ───────
# When unset, CAPTCHA verification is skipped (local dev only — set in production).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Plans & abuse limits (defaults shown; all optional) ───────────────────────
# DEV ONLY: "true" unlocks all plan-gated features (quoting, branding, no
# watermark, 3000 renders/mo) for every account. DELETE BEFORE LAUNCH —
# real plan gates resume automatically when unset. Cost guardrails (render
# budget cap, global daily cap, daily spend ceiling) stay active regardless.
DEV_UNLOCK_ALL_FEATURES=false
# Monthly render caps per plan
RENDER_LIMIT_FREE=5
RENDER_LIMIT_PRO=150
RENDER_LIMIT_TEAM=300
# Per-org daily spend ceilings (auto-pauses the account when exceeded)
DAILY_COST_CEILING_FREE_USD=0.75
DAILY_COST_CEILING_PRO_USD=5
DAILY_COST_CEILING_TEAM_USD=10
# Global daily spend cap — all new jobs 503 when exceeded
GLOBAL_DAILY_COST_CAP_USD=20
# Rate limits (sliding windows)
RATELIMIT_JOBS_PER_MIN=5
RATELIMIT_JOBS_PER_HOUR=30
RATELIMIT_JOBS_IP_PER_MIN=10
RATELIMIT_UPLOADS_PER_MIN=10
RATELIMIT_UPLOADS_IP_PER_MIN=20
# Public lead form (IP-only)
RATELIMIT_LEADS_IP_PER_MIN=3
RATELIMIT_LEADS_IP_PER_HOUR=10

# ── Observability ─────────────────────────────────────────────────────────────
AXIOM_API_TOKEN=
AXIOM_DATASET=hvac-visualizer
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# DANGER: "true" bypasses ALL auth (preview/demo only). Never set in production.
PREVIEW_MODE=false
RENDER_MAX_ATTEMPTS=3
RENDER_WORKER_TIMEOUT_MS=55000
SHARE_LINK_TTL_SECONDS=2592000
# Proposal links live longer than render shares (default 90 days)
QUOTE_SHARE_TTL_SECONDS=7776000
BLOB_RETENTION_RENDERS_DAYS=365
BLOB_RETENTION_SOURCES_DAYS=90
BLOB_RETENTION_ANALYSIS_DAYS=30

# ── Cron security ─────────────────────────────────────────────────────────────
# Vercel sets this automatically in production; set manually for local cron testing
CRON_SECRET=

# ── fal.ai (AI image generation) ──────────────────────────────────────────────
FAL_KEY=
# "max" = Flux Pro Kontext Max (~$0.055/image); "pro" = cheaper but lower quality
FAL_MODEL_TIER=max
FAL_COST_PER_IMAGE_USD=0.055
RENDER_BUDGET_CAP_USD=0.40

# ── Cost alerting ─────────────────────────────────────────────────────────────
DAILY_COST_ALERT_THRESHOLD_USD=0.35
WEEKLY_COST_REPORT_EMAIL=

# ── Resend (transactional email) ──────────────────────────────────────────────
# When unset, all email sends no-op with a warning (dev-safe).
RESEND_API_KEY=
# Verified sender, e.g. "HVAC Visualizer <notify@yourdomain.com>"
EMAIL_FROM=
