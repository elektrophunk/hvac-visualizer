generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum PlanTier {
  free
  pro
  team
}

model Organization {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  owner_id   String?
  owner      User?     @relation("OrgOwner", fields: [owner_id], references: [id])
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  // Billing (owner-billed; synced from Stripe by /api/webhooks/stripe)
  plan                   PlanTier  @default(free)
  plan_status            String?
  stripe_customer_id     String?   @unique
  stripe_subscription_id String?
  current_period_start   DateTime?
  current_period_end     DateTime?
  render_limit           Int       @default(5)
  seats                  Int       @default(1)

  // Company branding (feeds quotes, share pages, watermarks in Builds 2–3)
  logo_url       String?
  phone          String?
  license_number String?
  address        String?
  brand_color    String?
  website        String?

  // Abuse controls (daily cost circuit-breaker)
  paused_at    DateTime?
  pause_reason String?

  users    User[]
  projects Project[]
  quotes   Quote[]
  leads    Lead[]

  @@index([owner_id])
}

model User {
  id           String        @id @default(uuid())
  supabase_uid String        @unique
  email        String        @unique
  display_name String?
  org_id       String?
  org          Organization? @relation(fields: [org_id], references: [id])
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  deleted_at   DateTime?

  jobs       RenderJob[]
  renders    Render[]
  projects   Project[]
  quotes     Quote[]
  owned_orgs Organization[] @relation("OrgOwner")

  @@index([supabase_uid])
  @@index([org_id])
}

model Project {
  id         String        @id @default(uuid())
  name       String
  org_id     String?
  org        Organization? @relation(fields: [org_id], references: [id])
  owner_id   String
  owner      User          @relation(fields: [owner_id], references: [id])
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  jobs RenderJob[]
}

// ─── Equipment Catalog ────────────────────────────────────────────────────────

enum EquipmentCategory {
  // ── Ductless ──
  mini_split_head
  ductless_cassette
  mini_split_condenser
  ducted_mini_split
  floor_mount_mini_split
  ceiling_suspended_mini_split
  // ── Central cooling ──
  heat_pump_condenser
  central_air_handler
  evaporator_coil
  packaged_unit
  window_ac
  ptac
  // ── Heating ──
  furnace
  boiler
  baseboard_heater
  radiator
  unit_heater
  // ── Water heating ──
  gas_water_heater
  tankless_water_heater
  // ── Ventilation & air quality ──
  ventilator
  exhaust_fan
  whole_house_humidifier
  whole_house_dehumidifier
  air_cleaner
  // ── Commercial ──
  rooftop_unit
  vrf_outdoor
  vrf_branch_box
  air_handling_unit
  fan_coil_unit
  air_cooled_chiller
  water_cooled_chiller
  cooling_tower
  makeup_air_unit
  // ── Infrastructure ──
  ductwork
  refrigerant_lineset
  // ── Fallback ──
  other
}

model Equipment {
  id                  String            @id @default(uuid())
  name                String
  slug                String            @unique
  category            EquipmentCategory
  manufacturer        String?
  model_number        String?
  btu_rating          Int?
  thumbnail_url       String?
  prompt_description  String            @default("")
  metadata            Json              @default("{}")
  is_active           Boolean           @default(true)
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  jobs RenderJob[]

  @@index([category, is_active])
}

// ─── Render Jobs ──────────────────────────────────────────────────────────────

enum JobStatus {
  queued
  processing
  awaiting_fal_result
  completed
  failed
}

enum FailureReason {
  CLAUDE_API_ERROR
  CLAUDE_JSON_INVALID
  FAL_API_ERROR
  STORAGE_ERROR
  TIMEOUT
  MODERATION_BLOCKED
  UNKNOWN
}

model RenderJob {
  id              String   @id @default(uuid())
  idempotency_key String   @unique

  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  project_id String?
  project    Project? @relation(fields: [project_id], references: [id])

  equipment_id String?
  equipment    Equipment? @relation(fields: [equipment_id], references: [id])

  user_prompt    String
  force_generate Boolean  @default(false)

  source_image_url       String
  source_image_width_px  Int?
  source_image_height_px Int?

  status              JobStatus      @default(queued)
  attempt_count       Int            @default(0)
  max_attempts        Int            @default(3)
  last_failure_reason FailureReason?
  failure_detail      String?
  poison_message      Boolean        @default(false)

  fal_request_id String?

  queue_latency_ms      Int?
  vision_latency_ms     Int?
  generation_latency_ms Int?
  total_latency_ms      Int?

  input_tokens  Int?
  output_tokens Int?
  cost_usd      Decimal?  @db.Decimal(10, 6)
  fal_cost_usd  Decimal?  @db.Decimal(10, 6)

  placement_viable Boolean?

  result_url        String?
  analysis_json_url String?

  queued_at    DateTime  @default(now())
  started_at   DateTime?
  completed_at DateTime?
  failed_at    DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  render Render?

  @@index([user_id, status])
  @@index([idempotency_key])
  @@index([status, queued_at])
  @@index([user_id, created_at(sort: Desc)])
}

// ─── Render Output ────────────────────────────────────────────────────────────

model Render {
  id      String    @id @default(uuid())
  job_id  String    @unique
  job     RenderJob @relation(fields: [job_id], references: [id])
  user_id String
  user    User      @relation(fields: [user_id], references: [id])

  source_image_url  String
  result_image_url  String
  analysis_json_url String?

  share_token          String?   @unique
  share_expires_at     DateTime?
  share_accessed_count Int       @default(0)

  realism_rating    Int?
  usefulness_rating Int?
  feedback_note     String?
  quote_accepted    Boolean?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  quotes        Quote[]
  quote_options QuoteOption[]
  leads         Lead[]

  @@index([user_id, created_at(sort: Desc)])
  @@index([share_token])
}

// ─── Quotes / Proposals ───────────────────────────────────────────────────────

enum QuoteStatus {
  draft
  sent
  accepted
  declined
}

model Quote {
  id        String @id @default(uuid())
  render_id String
  render    Render @relation(fields: [render_id], references: [id])
  user_id   String
  user      User   @relation(fields: [user_id], references: [id])
  org_id    String
  org       Organization @relation(fields: [org_id], references: [id])

  customer_name  String
  customer_email String?

  // Structured [{description, qty, unit_price}] — future auto-fill populates this
  line_items Json    @default("[]")
  notes      String?

  // Totals are always recomputed server-side from line_items
  subtotal Decimal @db.Decimal(10, 2)
  tax_rate Decimal @db.Decimal(5, 2) @default(0)
  tax      Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  status           QuoteStatus @default(draft)
  share_token      String      @unique
  share_expires_at DateTime
  viewed_count     Int         @default(0)
  responded_at     DateTime?

  // Good/Better/Best: which tier the customer accepted (null = base estimate)
  accepted_option_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  options QuoteOption[]
  leads   Lead[]

  @@index([user_id, created_at(sort: Desc)])
  @@index([org_id])
  @@index([share_token])
}

// Good/Better/Best tiers on a proposal. Totals computed server-side with the
// quote-level tax_rate. A quote with no options is a plain single estimate.
model QuoteOption {
  id       String  @id @default(uuid())
  quote_id String
  quote    Quote   @relation(fields: [quote_id], references: [id], onDelete: Cascade)
  label    String
  render_id String?
  render    Render? @relation(fields: [render_id], references: [id])

  line_items Json    @default("[]")
  subtotal   Decimal @db.Decimal(10, 2)
  tax        Decimal @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)
  sort_order Int     @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([quote_id, sort_order])
}

// ─── Leads ────────────────────────────────────────────────────────────────────

enum LeadStatus {
  new
  contacted
  closed
}

model Lead {
  id     String       @id @default(uuid())
  org_id String
  org    Organization @relation(fields: [org_id], references: [id])

  render_id String?
  render    Render? @relation(fields: [render_id], references: [id])
  quote_id  String?
  quote     Quote?  @relation(fields: [quote_id], references: [id])

  name    String
  phone   String?
  email   String?
  message String?
  status  LeadStatus @default(new)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([org_id, created_at(sort: Desc)])
  @@index([org_id, status])
}
